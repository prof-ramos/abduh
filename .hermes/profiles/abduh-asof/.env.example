# .env.example — Variáveis de ambiente para perfil Hermes-Agent (Abduh/ASOF)
# Copie este arquivo para .env e preencha com suas credenciais reais

# ============================================
# Credenciais da API Gemini
# ============================================
# Obtenha sua chave em: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaSyABCdefGHIjklMNOpqrSTUvwxYZ

# ============================================
# Credenciais do Telegram Bot
# ============================================
# Crie seu bot em: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# IDs de usuários permitidos (separados por vírgula)
# Para obter seu ID: https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/getUpdates
TELEGRAM_ALLOWED_USERS=123456789

# ============================================
# Webhook do Telegram (Fase 2)
# ============================================
# URL HTTPS onde o Telegram enviará as atualizações
TELEGRAM_WEBHOOK_URL=https://seu-dominio.com/telegram

# Token secreto para autenticação de requisições webhook
# Gere com: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=abc123def456ghi789jkl012mno345pqr678stu901vwx234yz

# ============================================
# Configurações de API (Fase 2)
# ============================================
# Timeout para requisições da API (em segundos)
API_TIMEOUT=120

# Max tokens por resposta
MAX_TOKENS=4096

# ============================================
# Configurações de Logging (Fase 2)
# ============================================
# Nível de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================
# Configurações de Segurança (Fase 2)
# ============================================
# Verificar SSL em requisições externas
VERIFY_SSL=true

# Timeout para requisições externas (em segundos)
EXTERNAL_TIMEOUT=30

# ============================================
# Configurações de Rate Limiting (Fase 2)
# ============================================
# Habilitar rate limiting
RATE_LIMITING_ENABLED=true

# Máximo de requisições por minuto
MAX_REQUESTS_PER_MINUTE=100

# Máximo de requisições por usuário por minuto
MAX_REQUESTS_PER_USER_PER_MINUTE=10

# ============================================
# Configurações de Observabilidade (Fase 2)
# ============================================
# Habilitar Prometheus metrics
PROMETHEUS_ENABLED=false

# Porta do Prometheus metrics
PROMETHEUS_PORT=9090

# Habilitar health check
HEALTH_CHECK_ENABLED=true

# Porta do health check
HEALTH_CHECK_PORT=8000

# ============================================
# Configurações de Cron (Fase 2)
# ============================================
# Habilitar cron jobs
CRON_ENABLED=true

# ============================================
# Notas Importantes
# ============================================
#
# 1. Sempre mantenha este arquivo com permissões restritas:
#    chmod 600 ~/.hermes/profiles/abduh-asof/.env
#
# 2. Nunca commit este arquivo no repositório Git
#
# 3. Para Fase 1 (validação via Claude Project), use:
#    OPENAI_API_KEY=sua-chave-aqui
#
# 4. Para Fase 2 (Hermes-Agent com Gemini), use:
#    GEMINI_API_KEY=sua-chave-aqui
#
# 5. Para Fase 2 (Hermes-Agent com Claude), use:
#    ANTHROPIC_API_KEY=sua-chave-aqui
#    model.provider: anthropic
#    model.base_url: https://api.anthropic.com/v1